<div class="p-4 mb-4 text-sm rounded-lg border mx-4 sm:mx-6 lg:mx-8 mt-4 flex items-center justify-between <%= variant_classes %>"
     role="alert"
     data-controller="alert"
     data-alert-auto-dismiss-value="<%= auto_dismiss? %>"
     data-alert-dismissible-value="<%= dismissible? %>">
  <div class="flex items-center">
    <% if show_icon? %>
      <svg class="w-5 h-5 mr-2 shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <%= icon_path.html_safe %>
      </svg>
    <% end %>
    <%= text %>
  </div>
  <% if dismissible? %>
    <button type="button" class="<%= dismiss_classes %>" data-action="alert#dismiss">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    </button>
  <% end %>
</div>
