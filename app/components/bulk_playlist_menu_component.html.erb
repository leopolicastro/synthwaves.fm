<div class="relative" data-controller="playlist-menu" data-action="click@window->playlist-menu#close">
  <button data-action="click->playlist-menu#toggle" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-gray-400 bg-gray-800 border border-gray-700 rounded-lg hover:bg-gray-700 hover:text-neon-cyan">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Add All to Playlist
  </button>
  <div data-playlist-menu-target="menu" class="hidden absolute right-0 z-10 mt-1 w-56 bg-gray-800 border border-gray-700 rounded-lg shadow-lg">
    <form action="<%= playlists_path %>" method="post">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      <input type="hidden" name="playlist[name]" value="<%= new_playlist_name %>">
      <% track_ids.each do |id| %>
        <input type="hidden" name="track_ids[]" value="<%= id %>">
      <% end %>
      <button type="submit" class="block w-full text-left px-4 py-2 text-sm font-medium text-neon-cyan hover:bg-gray-700 rounded-t-lg">
        New Playlist
      </button>
    </form>
    <% if playlists.any? %>
      <div class="border-t border-gray-700"></div>
      <div class="p-2 border-b border-gray-700">
        <input type="text"
               data-playlist-menu-target="input"
               data-action="input->playlist-menu#filter keydown->playlist-menu#filterKeydown"
               placeholder="Search playlists…"
               class="w-full px-2 py-1 text-sm text-gray-200 bg-gray-900 border border-gray-600 rounded focus:outline-none focus:border-neon-cyan">
      </div>
      <div class="max-h-64 overflow-y-auto">
        <% playlists.each do |playlist| %>
          <div data-playlist-menu-target="item" data-playlist-name="<%= playlist.name %>">
            <form action="<%= playlist_tracks_path(playlist) %>" method="post">
              <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
              <% track_ids.each do |id| %>
                <input type="hidden" name="track_ids[]" value="<%= id %>">
              <% end %>
              <button type="submit" class="block w-full text-left px-4 py-2 text-sm text-gray-400 hover:bg-gray-700 hover:text-neon-cyan">
                <%= playlist.name %>
              </button>
            </form>
          </div>
        <% end %>
      </div>
      <div data-playlist-menu-target="emptyMessage" style="display: none" class="px-4 py-2 text-sm text-gray-500">No matching playlists</div>
    <% end %>
  </div>
</div>
