<div class="group bg-gray-800/60 border border-gray-700 rounded-xl p-4 hover:border-neon-cyan/50 hover:bg-gray-800 transition-all duration-200 w-full">
  <div class="flex items-center gap-3">
    <div class="w-12 h-12 rounded-lg bg-gray-700 flex items-center justify-center overflow-hidden flex-shrink-0">
      <% if channel.logo_url.present? %>
        <img src="<%= channel.logo_url %>" alt="<%= channel.name %>" class="w-full h-full object-contain" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <span class="w-full h-full items-center justify-center hidden <%= initials_color %> text-white text-xs font-bold"><%= initials %></span>
      <% else %>
        <span class="w-full h-full flex items-center justify-center <%= initials_color %> text-white text-xs font-bold"><%= initials %></span>
      <% end %>
    </div>
    <div class="min-w-0 flex-1">
      <%= link_to channel.name, helpers.iptv_channel_path(channel),
            class: "text-sm font-medium text-white truncate block hover:text-neon-cyan transition-colors",
            data: { turbo_frame: "_top" } %>
      <div class="flex items-center gap-2 mt-0.5">
        <% if channel.iptv_category.present? %>
          <span class="text-xs text-gray-400"><%= channel.iptv_category.name %></span>
        <% end %>
        <% if channel.country.present? %>
          <span class="text-xs text-gray-500"><%= channel.country %></span>
        <% end %>
      </div>
    </div>
    <button type="button"
            class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-700 transition-colors"
            data-action="click->hls-player#play"
            data-hls-player-url-param="<%= channel.stream_url %>"
            data-hls-player-name-param="<%= channel.name %>"
            title="Play">
      <svg class="w-5 h-5 text-neon-cyan" fill="currentColor" viewBox="0 0 24 24">
        <path d="M8 5v14l11-7z"/>
      </svg>
    </button>
  </div>
</div>
