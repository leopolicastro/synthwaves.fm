<%= link_to missing_album_artist_path(artist, mbid: entry[:mbid]), class: "group", data: { turbo_frame: "_top" } do %>
  <div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden opacity-50 hover:opacity-80 transition-opacity">
    <img src="<%= entry[:cover_art_url] %>"
         alt="<%= entry[:title] %>"
         class="w-full aspect-square object-cover grayscale"
         loading="lazy"
         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
    <div class="w-full aspect-square bg-gray-700 items-center justify-center hidden">
      <svg class="w-12 h-12 text-gray-500" fill="currentColor" viewBox="0 0 20 20"><path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"/></svg>
    </div>
    <div class="p-3">
      <div class="font-medium text-gray-400 truncate"><%= entry[:title] %></div>
      <div class="text-sm text-gray-500">
        <%= entry[:year] %>
        <span class="ml-1 text-xs text-neon-cyan">+ Import</span>
      </div>
    </div>
  </div>
<% end %>
