<% content_for :meta_title, "#{@artist.name} — synthwaves.fm" %>
<% content_for :meta_description, "Listen to #{@artist.name}. #{pluralize(@albums.size, 'album')}." %>
<% if (first_cover = @albums.find { |a| a.cover_image.attached? }&.cover_image) %>
  <% content_for :meta_image, og_image_url_for(first_cover) %>
<% end %>
<% content_for :meta_type, "music.musician" %>

<div class="w-full">
  <div class="mb-6">
    <%= render Button::Component.new(label: "← Artists", behavior: :navigation, link_url: artists_path, style: :link) %>
  </div>

  <div class="flex items-center gap-3 mb-6">
    <h1 class="text-3xl font-bold font-display"><%= @artist.name %></h1>
    <%= render "favorites/button", favorable: @artist, favorited: Current.user.favorites.exists?(favorable: @artist) %>
    <% if Current.user.admin? %>
      <%= render Button::Component.new(label: "Edit", behavior: :navigation, link_url: edit_artist_path(@artist), style: :secondary, size: :small) %>
      <%= button_to "Delete", artist_path(@artist), method: :delete, class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-red-400 bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors", data: { turbo_confirm: "Delete #{@artist.name}, #{pluralize(@artist.albums.size, 'album')}, and #{pluralize(@artist.tracks.size, 'track')}? This cannot be undone." } %>
    <% end %>
  </div>

  <% if @artist.musicbrainz_artist_id.present? %>
    <turbo-frame id="discography" src="<%= discography_artist_path(@artist) %>" loading="lazy">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
        <% @albums.each do |album| %>
          <%= render "artists/album_card", album: album %>
        <% end %>
      </div>
    </turbo-frame>
  <% else %>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
      <% @albums.each do |album| %>
        <%= render "artists/album_card", album: album %>
      <% end %>
    </div>
  <% end %>
</div>
