<div id="download_<%= download.id %>" class="bg-gray-800 border border-gray-700 rounded-lg p-4 shadow-lg max-w-sm">
  <div class="flex items-start justify-between gap-2">
    <div class="min-w-0 flex-1">
      <p class="text-sm font-medium text-white truncate"><%= download.filename %></p>
      <% if download.pending? %>
        <span class="text-xs text-yellow-400">Queued...</span>
      <% elsif download.processing? %>
        <span class="text-xs text-neon-cyan">Preparing...</span>
        <div class="mt-2 w-full bg-gray-700 rounded-full h-2">
          <div class="bg-neon-cyan h-2 rounded-full transition-all duration-300" style="width: <%= download.progress_percentage %>%"></div>
        </div>
        <p class="text-xs text-gray-400 mt-1"><%= download.processed_tracks %>/<%= download.total_tracks %> tracks</p>
      <% elsif download.ready? %>
        <span class="text-xs text-green-400">Ready</span>
        <%= render ButtonComponent.new(label: "Download", behavior: :navigation, link_url: file_download_path(download), size: :extra_small, extra_classes: "mt-2") %>
      <% elsif download.failed? %>
        <span class="text-xs text-red-400">Failed</span>
        <% if download.error_message.present? %>
          <p class="text-xs text-gray-400 mt-1"><%= download.error_message %></p>
        <% end %>
      <% elsif download.cancelled? %>
        <span class="text-xs text-gray-400">Cancelled</span>
      <% end %>
    </div>
    <% if download.pending? || download.processing? %>
      <%= button_to download_path(download), method: :delete, class: "text-gray-400 hover:text-red-400", title: "Cancel download" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      <% end %>
    <% elsif download.ready? || download.failed? || download.cancelled? %>
      <button onclick="this.closest('[id^=download_]').remove()" class="text-gray-400 hover:text-white">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    <% end %>
  </div>
</div>
