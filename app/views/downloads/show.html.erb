<div class="w-full max-w-lg">
  <div class="mb-6">
    <%= render ButtonComponent.new(label: "← Library", behavior: :navigation, link_url: library_path, style: :link) %>
  </div>

  <div class="bg-gray-800 rounded-lg border border-gray-700 p-6">
    <h1 class="text-2xl font-bold font-display text-white mb-4">Download</h1>

    <div id="download_<%= @download.id %>">
      <p class="text-sm text-gray-400 mb-2"><%= @download.filename %></p>

      <% if @download.pending? %>
        <p class="text-yellow-400">Queued for processing...</p>
      <% elsif @download.processing? %>
        <p class="text-neon-cyan">Preparing your download...</p>
        <div class="mt-3 w-full bg-gray-700 rounded-full h-2.5">
          <div class="bg-neon-cyan h-2.5 rounded-full transition-all duration-300" style="width: <%= @download.progress_percentage %>%"></div>
        </div>
        <p class="text-sm text-gray-400 mt-2"><%= @download.processed_tracks %>/<%= @download.total_tracks %> tracks processed</p>
      <% elsif @download.ready? %>
        <p class="text-green-400 mb-4">Your download is ready!</p>
        <%= render ButtonComponent.new(label: "Download File", behavior: :navigation, link_url: file_download_path(@download)) %>
      <% elsif @download.failed? %>
        <p class="text-red-400">Download failed.</p>
        <% if @download.error_message.present? %>
          <p class="text-sm text-gray-400 mt-2"><%= @download.error_message %></p>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
