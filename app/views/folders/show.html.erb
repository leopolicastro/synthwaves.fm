<div class="w-full">
  <div class="mb-6">
    <%= render Button::Component.new(label: "← Back", behavior: :navigation, link_url: tv_path(tab: "videos"), style: :link) %>
  </div>

  <div class="flex flex-col sm:flex-row items-start gap-6 mb-8">
    <% if @folder.cover_image.attached? %>
      <%= image_tag @folder.cover_image, class: "w-32 h-32 rounded-lg object-cover" %>
    <% elsif (first_thumb = @folder.videos.detect { |v| v.thumbnail.attached? }) %>
      <%= image_tag first_thumb.thumbnail, class: "w-32 h-32 rounded-lg object-cover" %>
    <% else %>
      <div class="w-32 h-32 rounded-lg bg-gray-800 flex items-center justify-center">
        <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
        </svg>
      </div>
    <% end %>

    <div class="flex-1">
      <h1 class="text-3xl font-bold font-display text-white"><%= @folder.name %></h1>
      <% if @folder.description.present? %>
        <p class="text-gray-400 mt-1"><%= @folder.description %></p>
      <% end %>
      <div class="mt-2 text-sm text-gray-400 space-x-4">
        <span><%= @folder.videos.count %> video(s)</span>
        <% if @processing_count > 0 %>
          <span class="text-neon-cyan"><%= @processing_count %> processing</span>
        <% end %>
        <% if @failed_count > 0 %>
          <span class="text-red-400"><%= @failed_count %> failed</span>
        <% end %>
      </div>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <%= render "favorites/button", favorable: @folder, favorited: Current.user.favorites.exists?(favorable: @folder) %>
        <%= render Button::Component.new(label: "Edit", behavior: :navigation, link_url: edit_folder_path(@folder), style: :secondary) %>
        <%= button_to "Delete", folder_path(@folder), method: :delete, data: { turbo_confirm: "Are you sure? Videos will be kept but unlinked." }, class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700" %>
      </div>
    </div>
  </div>

  <turbo-frame id="folder-videos" data-turbo-action="advance">
    <form action="<%= folder_path(@folder) %>" method="get" data-controller="search" data-search-target="form" class="mb-4">
      <div class="flex flex-col sm:flex-row gap-3">
        <input type="text" name="q" value="<%= @query %>" placeholder="Search videos..."
               class="flex-1 rounded-lg bg-gray-800 border-gray-700 text-white text-lg px-4 py-3 focus:outline-neon-cyan"
               data-search-target="input" data-action="input->search#submit">

        <div class="flex flex-wrap items-center gap-2">
          <% if @available_seasons.any? %>
            <select name="season" data-action="change->search#submit" class="text-sm rounded-lg border border-gray-600 bg-gray-700 text-white px-3 py-2 focus:outline-neon-cyan">
              <option value="">All Seasons</option>
              <% @available_seasons.each do |season| %>
                <option value="<%= season %>" <%= "selected" if @season == season.to_s %>>Season <%= season %> (<%= @season_counts[season] %>)</option>
              <% end %>
            </select>
          <% end %>

          <select name="sort" data-action="change->search#submit" class="text-sm rounded-lg border border-gray-600 bg-gray-700 text-white px-3 py-2 focus:outline-neon-cyan">
            <% Video::FOLDER_SORT_OPTIONS.each do |value, label| %>
              <option value="<%= value %>" <%= "selected" if value == @sort %>><%= label %></option>
            <% end %>
          </select>

          <select name="direction" data-action="change->search#submit" class="text-sm rounded-lg border border-gray-600 bg-gray-700 text-white px-3 py-2 focus:outline-neon-cyan">
            <option value="asc" <%= "selected" if @direction == "asc" %>>Ascending</option>
            <option value="desc" <%= "selected" if @direction == "desc" %>>Descending</option>
          </select>
        </div>
      </div>
    </form>

    <% if @videos.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        <% @videos.each do |video| %>
          <%= render VideoCard::Component.new(video: video, show_episode_number: true) %>
        <% end %>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="mt-6 flex justify-center">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-16 text-gray-400">
        <% if @query.present? || @season.present? %>
          <p class="text-lg mb-2">No matching videos</p>
          <p>Try adjusting your search or filters.</p>
        <% else %>
          <p class="text-lg mb-2">No ready videos yet</p>
          <p>Videos are still being processed.</p>
        <% end %>
      </div>
    <% end %>
  </turbo-frame>
</div>
