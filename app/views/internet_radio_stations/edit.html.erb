<div class="w-full max-w-2xl mx-auto">
  <div class="mb-4">
    <%= render ButtonComponent.new(label: "← Back to station", behavior: :navigation, link_url: internet_radio_station_path(@station), style: :link, size: :small) %>
  </div>

  <h1 class="text-3xl font-bold font-display mb-6">Edit Station</h1>

  <div class="bg-gray-800 rounded-lg border border-gray-700 p-6">
    <%= form_with model: @station, class: "space-y-4" do |f| %>
      <% if @station.errors.any? %>
        <div class="bg-red-900/50 border border-red-700 rounded-lg p-4">
          <ul class="text-sm text-red-300 list-disc list-inside">
            <% @station.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-400 mb-1" %>
        <%= f.text_field :name, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-900 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan" %>
      </div>

      <div>
        <%= f.label :stream_url, "Stream URL", class: "block text-sm font-medium text-gray-400 mb-1" %>
        <%= f.url_field :stream_url, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-900 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan" %>
      </div>

      <div>
        <%= f.label :homepage_url, "Homepage URL", class: "block text-sm font-medium text-gray-400 mb-1" %>
        <%= f.url_field :homepage_url, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-900 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan" %>
      </div>

      <div>
        <%= f.label :favicon_url, "Favicon URL", class: "block text-sm font-medium text-gray-400 mb-1" %>
        <%= f.url_field :favicon_url, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-900 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :country, class: "block text-sm font-medium text-gray-400 mb-1" %>
          <%= f.text_field :country, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-900 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan" %>
        </div>
        <div>
          <%= f.label :country_code, class: "block text-sm font-medium text-gray-400 mb-1" %>
          <%= f.text_field :country_code, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-900 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan" %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :codec, class: "block text-sm font-medium text-gray-400 mb-1" %>
          <%= f.text_field :codec, placeholder: "MP3, AAC, OGG", class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-900 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-neon-cyan" %>
        </div>
        <div>
          <%= f.label :bitrate, "Bitrate (kbps)", class: "block text-sm font-medium text-gray-400 mb-1" %>
          <%= f.number_field :bitrate, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-900 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan" %>
        </div>
      </div>

      <div>
        <%= f.label :tags, "Tags (comma-separated)", class: "block text-sm font-medium text-gray-400 mb-1" %>
        <%= f.text_field :tags, class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-700 bg-gray-900 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan" %>
      </div>

      <div class="flex justify-end">
        <%= f.submit "Save Changes", class: "px-4 py-2 text-sm font-medium text-white bg-neon-pink rounded-lg hover:bg-neon-pink/80 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
