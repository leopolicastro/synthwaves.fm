<section class="mb-8">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xl font-semibold text-gray-900 dark:text-white"><%= title %></h2>
    <% if defined?(see_all_path) && see_all_path.present? %>
      <%= link_to "See all", see_all_path, class: "text-sm text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300" %>
    <% end %>
  </div>
  <div class="flex gap-4 overflow-x-auto pb-2 scrollbar-hide">
    <%= yield %>
  </div>
</section>
