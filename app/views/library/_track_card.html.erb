<%= link_to track_path(track), class: "group w-40 flex-shrink-0" do %>
  <div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden hover:border-neon-purple/40 hover:shadow-lg transition-all">
    <%= cover_image_or_placeholder(track.album.cover_image, size: :card_sm, rounded: "") %>
    <div class="p-2">
      <div class="font-medium text-sm text-white group-hover:text-neon-cyan truncate"><%= track.title %></div>
      <div class="text-xs text-gray-400 truncate"><%= track.artist.name %></div>
    </div>
  </div>
<% end %>
