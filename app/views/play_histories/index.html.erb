<div class="w-full">
  <h1 class="text-3xl font-bold mb-6">Recently Played</h1>

  <% if @recent.any? %>
    <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
      <% @recent.each do |ph| %>
        <%= render TrackRowComponent.new(track: ph.track, link_title: true, show_duration: false) do |c| %>
          <% c.with_trailing do %>
            <span class="text-sm text-gray-500"><%= time_ago_in_words(ph.played_at) %> ago</span>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500">No play history yet.</p>
  <% end %>
</div>
