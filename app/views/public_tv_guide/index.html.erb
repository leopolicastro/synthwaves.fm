<% content_for :title, "TV Guide — synthwaves.fm" %>
<% content_for :meta_title, "TV Guide — synthwaves.fm" %>
<% content_for :meta_description, "Browse what's on live TV. See current and upcoming programmes across all channels." %>
<div class="min-h-screen flex flex-col" data-controller="tv-page public-tv">
  <%# Nav %>
  <nav class="w-full py-4 px-4 sm:py-5 sm:px-6">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <%= link_to root_path do %>
        <%= render(Logo::Component.new(size: :md, icon: true, text: false)) %>
      <% end %>
      <div class="flex items-center gap-4">
        <%= link_to "Radio", public_radio_stations_path, class: "text-sm text-gray-400 hover:text-neon-cyan transition-colors" %>
        <% if authenticated? %>
          <%= link_to "Dashboard", root_path, class: "text-sm text-gray-400 hover:text-neon-cyan transition-colors" %>
        <% else %>
          <%= render Button::Component.new(label: "Log In", behavior: :navigation, link_url: new_session_path, style: :link) %>
        <% end %>
      </div>
    </div>
  </nav>
  <%# Player view (hidden until a channel is tuned) %>
  <div data-public-tv-target="player" class="hidden flex-1">
    <%= render TvPlayer::Component.new %>
    <div class="max-w-4xl xl:max-w-7xl mx-auto px-5 mt-4">
      <button type="button" data-action="public-tv#showGuide"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm border border-gray-600 text-gray-400 rounded-lg hover:border-neon-cyan hover:text-neon-cyan transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Guide
      </button>
    </div>
  </div>
  <%# Guide view %>
  <div data-public-tv-target="guide">
    <%# Header %>
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 pt-8 sm:pt-12 pb-6">
      <div class="flex items-end gap-4 mb-2">
        <h1 class="text-4xl sm:text-5xl font-bold font-display text-white tracking-tight">TV Guide</h1>
        <% if @channels.any? %>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-sunset-orange/10 text-sunset-orange border border-sunset-orange/30 mb-1.5">
            <%= @channels.size %> channels
          </span>
        <% end %>
      </div>
      <p class="text-gray-500 text-lg max-w-xl">Browse what's on across all channels. Live programmes and upcoming schedules.</p>
    </div>
    <%# Guide grid %>
    <div class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 pb-16"
         data-controller="tv-guide tv-remote"
         data-tv-guide-window-start-value="<%= @window_start.to_i %>"
         data-tv-guide-window-end-value="<%= @window_end.to_i %>"
         data-tv-guide-pixels-per-minute-value="7"
         data-tv-remote-channels-value="<%= retro_tv_channels_json(@channels, @programmes_by_channel) %>">
      <%# Filters %>
      <div class="flex flex-col sm:flex-row gap-3 mb-4">
        <%= form_with url: public_tv_guide_path, method: :get, class: "flex-1" do |f| %>
          <%= hidden_field_tag :category, params[:category] %>
          <%= hidden_field_tag :country, params[:country] %>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search channels..."
                   class="w-full pl-9 pr-3 py-2 text-sm rounded-lg border border-gray-600 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan focus:border-transparent placeholder-gray-500">
          </div>
        <% end %>
        <% if @countries.any? %>
          <%= form_with url: public_tv_guide_path, method: :get do %>
            <%= hidden_field_tag :category, params[:category] %>
            <%= hidden_field_tag :q, params[:q] %>
            <select name="country" onchange="this.form.requestSubmit()"
                    class="px-3 py-2 text-sm rounded-lg border border-gray-600 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan">
              <option value="">All Countries</option>
              <% @countries.each do |country| %>
                <option value="<%= country %>" <%= "selected" if params[:country] == country %>><%= country %></option>
                <% end %>
              </select>
            <% end %>
          <% end %>
          <% if @categories.any? %>
            <%= form_with url: public_tv_guide_path, method: :get do %>
              <%= hidden_field_tag :q, params[:q] %>
              <%= hidden_field_tag :country, params[:country] %>
              <select name="category" onchange="this.form.requestSubmit()"
                    class="px-3 py-2 text-sm rounded-lg border border-gray-600 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-neon-cyan">
                <option value="">All Categories</option>
                <% @categories.each do |category| %>
                  <option value="<%= category.slug %>" <%= "selected" if params[:category] == category.slug %>><%= category.name %></option>
                  <% end %>
                </select>
              <% end %>
            <% end %>
          </div>
          <%# Time navigation %>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
            <div class="flex items-center gap-2">
              <button type="button" data-action="tv-guide#navigateBack"
              class="px-3 py-1.5 text-sm border border-gray-600 text-gray-400 rounded-lg hover:border-neon-cyan hover:text-neon-cyan transition-colors">
                &larr; Back
              </button>
              <button type="button" data-action="tv-guide#jumpToNow"
              class="px-3 py-1.5 text-sm bg-neon-cyan/10 border border-neon-cyan/50 text-neon-cyan rounded-lg hover:bg-neon-cyan/20 transition-colors">
                Now
              </button>
              <button type="button" data-action="tv-guide#navigateForward"
              class="px-3 py-1.5 text-sm border border-gray-600 text-gray-400 rounded-lg hover:border-neon-cyan hover:text-neon-cyan transition-colors">
                Forward &rarr;
              </button>
            </div>
            <div class="text-sm text-gray-400">
              <%= @window_start.strftime("%-I:%M %p") %> &ndash; <%= @window_end.strftime("%-I:%M %p %Z") %>
            </div>
          </div>
          <%# EPG Grid %>
          <% if @channels.any? %>
            <div class="border border-gray-700 rounded-xl overflow-hidden bg-gray-900/80">
              <div class="flex">
                <%# Sticky channel column %>
                <div class="flex-shrink-0 w-[160px] z-20 bg-gray-900">
                  <%# Time header spacer %>
                  <div class="h-10 border-b border-gray-700 bg-gray-900"></div>
                  <%# Channel rows %>
                  <% @channels.each_with_index do |channel, index| %>
                    <div class="h-16 border-b border-gray-700/60 flex items-center gap-2 px-3 bg-gray-900 hover:bg-gray-800 transition-colors cursor-pointer"
                     data-action="click->tv-remote#tune"
                      data-tv-remote-url-param="<%= channel.stream_url %>"
                      data-tv-remote-name-param="<%= channel.name %>"
                      data-tv-remote-index-param="<%= index %>">
                      <div class="w-8 h-8 rounded bg-gray-700 flex items-center justify-center overflow-hidden flex-shrink-0">
                        <% if channel.logo_url.present? %>
                          <img src="<%= channel.logo_url %>" alt="" class="w-full h-full object-contain" loading="lazy">
                        <% else %>
                          <span class="text-[10px] font-bold text-white"><%= channel.name.scan(/[A-Z0-9]/).first(3).join.presence || channel.name[0..1].upcase %></span>
                        <% end %>
                      </div>
                      <span class="text-xs font-medium text-white truncate flex-1"><%= channel.name %></span>
                    </div>
                  <% end %>
                </div>
                <%# Scrollable programme grid %>
                <div class="flex-1 overflow-x-auto" data-tv-guide-target="grid">
                  <div class="relative" style="width: <%= guide_grid_width(@window_start, @window_end) %>px; min-width: 100%;">
                    <%# Time header %>
                    <div class="h-10 border-b border-gray-700 relative bg-gray-900/90">
                      <% guide_time_slots(@window_start, @window_end).each do |slot| %>
                        <% left = time_slot_left_px(slot, @window_start) %>
                        <div class="absolute top-0 h-full flex items-center border-l border-gray-700/60 pl-2"
                         style="left: <%= left %>px;">
                          <span class="text-xs text-gray-400 whitespace-nowrap"><%= slot.strftime("%-I:%M %p") %></span>
                        </div>
                      <% end %>
                    </div>
                    <%# Programme rows %>
                    <% @channels.each_with_index do |channel, index| %>
                      <div class="h-16 border-b border-gray-700/60 relative">
                        <% programmes = @programmes_by_channel[channel.tvg_id] || [] %>
                        <% if programmes.any? %>
                          <% programmes.each do |programme| %>
                            <% left = programme_left_px(programme, @window_start) %>
                            <% width = programme_width_px(programme, @window_start, @window_end) %>
                            <% next if width < 2 %>
                            <div class="absolute top-1 bottom-1 rounded-md px-2 py-1 overflow-hidden cursor-pointer transition-all duration-150
                                <%= programme.live? ? 'bg-gray-800/90 border border-neon-cyan/50 shadow-[0_0_8px_rgba(0,255,255,0.1)]' : 'bg-gray-800 border border-gray-600 hover:border-neon-cyan/50 hover:bg-gray-700' %>"
                             style="left: <%= left %>px; width: <%= width %>px;"
                             data-action="click->tv-remote#tune"
                              data-tv-remote-url-param="<%= channel.stream_url %>"
                              data-tv-remote-name-param="<%= channel.name %>"
                              data-tv-remote-index-param="<%= index %>"
                              title="<%= programme.title %><%= " - #{programme.subtitle}" if programme.subtitle.present? %>">
                              <div class="text-xs font-medium text-white truncate leading-tight"><%= programme.title %></div>
                              <% if programme.subtitle.present? && width > 100 %>
                                <div class="text-[10px] text-gray-400 truncate leading-tight"><%= programme.subtitle %></div>
                              <% end %>
                              <% if programme.live? && width > 60 %>
                                <div class="mt-0.5 h-1 bg-gray-700 rounded-full overflow-hidden">
                                  <div class="h-full bg-neon-cyan rounded-full" style="width: <%= programme.progress_percentage %>%"></div>
                                </div>
                              <% end %>
                            </div>
                          <% end %>
                        <% else %>
                          <div class="absolute inset-0 flex items-center px-3">
                            <span class="text-xs text-gray-400 italic">No schedule info</span>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                    <%# Current time marker %>
                    <div data-tv-guide-target="timeMarker"
                     class="absolute top-0 bottom-0 w-0.5 bg-neon-cyan z-10 pointer-events-none"
                     style="display: none; box-shadow: 0 0 8px rgba(0, 255, 255, 0.5), 0 0 16px rgba(0, 255, 255, 0.2);">
                      <div class="w-2 h-2 bg-neon-cyan rounded-full -ml-[3px] -mt-1"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% else %>
            <%# Empty State %>
            <div class="flex flex-col items-center justify-center py-24 text-center">
              <div class="w-20 h-20 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center mb-6">
                <svg class="w-10 h-10 text-gray-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <h2 class="text-xl font-display font-bold text-gray-300 mb-2">No channels found</h2>
              <p class="text-gray-500 max-w-sm">There are no channels with programme data right now. Try adjusting your filters or check back later.</p>
            </div>
          <% end %>
        </div>
      </div>
      <%# Footer %>
      <footer class="w-full max-w-7xl mx-auto px-4 sm:px-6 pb-8">
        <div class="border-t border-gray-800 pt-6 flex items-center justify-between">
          <p class="text-gray-600 text-sm">
            Powered by <%= link_to "synthwaves.fm", root_path, class: "text-gray-500 hover:text-neon-cyan transition-colors" %>
          </p>
        </div>
      </footer>
    </div>
