<%# locals: (channel:, programme:, status: nil, size: :normal) %>
<% if status == "scheduled" %>
  <span class="inline-flex items-center" title="Scheduled">
    <svg class="<%= size == :small ? 'w-3 h-3' : 'w-4 h-4' %> text-amber-400" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="6"/></svg>
  </span>
<% elsif status == "recording" %>
  <span class="inline-flex items-center" title="Recording...">
    <span class="relative flex <%= size == :small ? 'h-3 w-3' : 'h-4 w-4' %>">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
      <svg class="relative <%= size == :small ? 'w-3 h-3' : 'w-4 h-4' %> text-red-500" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="6"/></svg>
    </span>
  </span>
<% elsif status == "processing" %>
  <span class="inline-flex items-center" title="Processing...">
    <svg class="<%= size == :small ? 'w-3 h-3' : 'w-4 h-4' %> text-neon-cyan animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
  </span>
<% elsif status == "ready" %>
  <span class="inline-flex items-center" title="Recorded">
    <svg class="<%= size == :small ? 'w-3 h-3' : 'w-4 h-4' %> text-green-400" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
    </svg>
  </span>
<% elsif programme.live? || programme.starts_at > Time.current %>
  <% if size == :small %>
    <%= button_to recordings_path(iptv_channel_id: channel.id, epg_programme_id: programme.id), method: :post,
          class: "p-0.5 text-red-400 hover:text-red-300 cursor-pointer",
          title: "Record", data: { turbo_confirm: "Record \"#{programme.title}\"?" } do %>
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="6"/></svg>
    <% end %>
  <% else %>
    <%= button_to recordings_path(iptv_channel_id: channel.id, epg_programme_id: programme.id), method: :post,
          class: "p-1.5 text-red-400 hover:text-red-300 border border-red-400/30 rounded-lg hover:border-red-400 transition-colors cursor-pointer",
          title: "Record", data: { turbo_confirm: "Record \"#{programme.title}\"?" } do %>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="6"/></svg>
    <% end %>
  <% end %>
<% end %>
