<div id="recording_<%= recording.id %>" class="bg-gray-800 border border-gray-700 rounded-lg p-4">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <p class="text-sm font-medium text-white truncate"><%= recording.title %></p>
      <p class="text-xs text-gray-400 mt-0.5"><%= recording.iptv_channel.name %></p>
      <p class="text-xs text-gray-500 mt-0.5">
        <%= recording.starts_at.strftime("%-I:%M %p") %> &ndash; <%= recording.ends_at.strftime("%-I:%M %p, %b %-d") %>
      </p>

      <div class="mt-2">
        <% if recording.scheduled? %>
          <span class="inline-flex items-center gap-1 text-xs text-yellow-400">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
            Scheduled
          </span>
        <% elsif recording.recording? %>
          <span class="inline-flex items-center gap-1 text-xs text-red-400">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
            </span>
            Recording...
          </span>
        <% elsif recording.processing? %>
          <span class="text-xs text-neon-cyan">Processing...</span>
        <% elsif recording.ready? %>
          <span class="text-xs text-green-400">Ready</span>
          <% if recording.duration %>
            <span class="text-xs text-gray-500 ml-2"><%= (recording.duration / 60).round %> min</span>
          <% end %>
        <% elsif recording.failed? %>
          <span class="text-xs text-red-400">Failed</span>
          <% if recording.error_message.present? %>
            <p class="text-xs text-gray-500 mt-1"><%= recording.error_message %></p>
          <% end %>
        <% elsif recording.cancelled? %>
          <span class="text-xs text-gray-500">Cancelled</span>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-2 flex-shrink-0">
      <% if recording.ready? && recording.file.attached? %>
        <%= link_to recording_path(recording), class: "p-1.5 text-neon-cyan hover:text-white transition-colors", title: "Watch", data: { turbo_frame: "_top" } do %>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <% end %>
        <%= link_to file_recording_path(recording), class: "p-1.5 text-gray-400 hover:text-white transition-colors", title: "Download" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        <% end %>
      <% end %>
      <% if recording.cancellable? %>
        <%= button_to cancel_recording_path(recording), method: :post, class: "p-1.5 text-yellow-400 hover:text-yellow-300 transition-colors cursor-pointer", title: "Cancel", data: { turbo_confirm: "Cancel this recording?" } do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <% end %>
      <% end %>
      <% unless recording.recording? %>
        <%= button_to recording_path(recording), method: :delete, class: "p-1.5 text-gray-500 hover:text-red-400 transition-colors cursor-pointer", title: "Delete", data: { turbo_confirm: "Delete this recording?" } do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
