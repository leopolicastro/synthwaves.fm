<div class="w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold font-display">Tracks</h1>
    <%= render Button::Component.new(label: "Upload", behavior: :navigation, link_url: new_track_path) %>
  </div>
  <%= render CollectionLayout::Component.new(
    collection: @tracks,
    page_key: "tracks",
    form_url: tracks_path,
    turbo_frame: "tracks-list",
    placeholder: "Search by title, artist, or album...",
    query: @query,
    pagy: @pagy,
    sort_options: Track::SORT_OPTIONS,
    sort: @sort,
    direction: @direction,
    view_toggle: false,
    container_classes: "bg-gray-800 rounded-lg border border-gray-700",
    content_frame: "tracks-list",
    empty_label: "tracks"
  ) do |c| %>
    <% if @genres.any? || @languages.any? || @decades.any? %>
      <% c.with_filters do %>
        <% if @genres.any? %>
          <select name="genre" data-action="change->search#submit" class="text-sm rounded-lg border border-gray-600 bg-gray-700 text-white px-3 py-2 focus:outline-neon-cyan">
            <option value="">All Genres</option>
            <% @genres.each do |genre| %>
              <option value="<%= genre %>" <%= "selected" if params[:genre] == genre %>><%= genre.titleize %></option>
            <% end %>
          </select>
        <% end %>
        <% if @languages.any? %>
          <select name="language" data-action="change->search#submit" class="text-sm rounded-lg border border-gray-600 bg-gray-700 text-white px-3 py-2 focus:outline-neon-cyan">
            <option value="">All Languages</option>
            <% @languages.each do |lang| %>
              <option value="<%= lang %>" <%= "selected" if params[:language] == lang %>><%= language_name(lang) %></option>
            <% end %>
          </select>
        <% end %>
        <% if @decades.any? %>
          <select name="decade" data-action="change->search#submit" class="text-sm rounded-lg border border-gray-600 bg-gray-700 text-white px-3 py-2 focus:outline-neon-cyan">
            <option value="">All Decades</option>
            <% @decades.each do |decade| %>
              <option value="<%= decade %>" <%= "selected" if params[:decade] == decade.to_s %>><%= decade_label(decade) %></option>
            <% end %>
          </select>
        <% end %>
      <% end %>
    <% end %>
    <% c.with_before_grid do %>
      <% if @query.present? && @tracks.any? %>
        <div class="flex justify-end mb-3">
          <%= render BulkPlaylistMenu::Component.new(
                tracks: @tracks,
                playlists: current_user_playlists,
                new_playlist_name: "Search: #{@query}"
              ) %>
        </div>
      <% end %>
    <% end %>
    <% @tracks.each do |track| %>
      <%= render TrackRow::Component.new(track: track, link_title: true, link_subtitle: true) do |c| %>
        <% c.with_trailing do %>
          <%= render "favorites/button", favorable: track, favorited: @favorited_track_ids.include?(track.id) %>
          <%= render "playlist_tracks/add_menu", track: track, playlists: current_user_playlists %>
          <%= link_to edit_track_path(track), data: { turbo_frame: "_top" }, class: "text-gray-400 hover:text-neon-cyan" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
