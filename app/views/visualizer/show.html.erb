<div class="container mx-auto px-4 py-6" data-controller="visualizer">
  <h1 class="text-2xl font-bold text-white mb-6">Visualizer</h1>

  <div class="relative w-full rounded-lg overflow-hidden bg-gray-900/50 border border-gray-700/50"
       style="min-height: 60vh"
       data-visualizer-target="container">
    <canvas data-visualizer-target="canvas" class="w-full h-full absolute inset-0"></canvas>
    <div data-visualizer-target="status"
         class="absolute inset-0 flex items-center justify-center text-gray-400 text-lg pointer-events-none">
      Play a track to see the visualizer
    </div>
  </div>
</div>
